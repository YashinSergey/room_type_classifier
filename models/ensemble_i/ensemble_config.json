{
  "model_name": "ensemble_i",
  "num_classes": 19,
  "image_size": 224,
  "batch_size": 32,
  "num_workers": 2,
  "combination": "stacking",
  "weight_power": 2.0,
  "members": [
    {
      "key": "convnext_nano",
      "checkpoint": "outputs/models/convnext_nano/convnext_nano_best.pt",
      "metrics_json": "models/convnext_nano/convnext_nano_metrics.json"
    },
    {
      "key": "resnet50",
      "checkpoint": "outputs/models/resnet50/resnet50_best.pt",
      "metrics_json": "reports/metrics/resnet50/resnet50_metrics.json"
    },
    {
      "key": "densenet121",
      "checkpoint": "outputs/models/densenet121/densenet121_best.pt",
      "metrics_json": "reports/metrics/densenet121/densenet121_metrics.json"
    }
  ],
  "meta_learner": {
    "checkpoint": "outputs/models/ensemble_i/stacking_meta.pt",
    "epochs": 200,
    "lr": 0.05,
    "weight_decay": 0.001,
    "patience": 25,
    "train_batch_size": 64
  },
  "per_class_weights": null,
  "ambiguous": {
    "enabled": true,
    "class_id": 18,
    "std_threshold": 0.03
  },
  "data": {
    "train_csv": "data/processed/train_df.csv",
    "train_images": "data/raw/train_images",
    "val_csv": "data/processed/val_df.csv",
    "val_images": "data/raw/val_images",
    "test_csv": "data/processed/test_df.csv",
    "test_images": "data/raw/test_images"
  },
  "output_dir": "outputs/models/ensemble_i",
  "metrics_dir": "reports/metrics/ensemble_i"
}
